{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prompt-architect.invalid/schemas/1.0/library.schema.json",
  "title": "Prompt Architect Library 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "version", "display_name", "options"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "$ref": "#/$defs/id" },
    "version": { "$ref": "#/$defs/version" },
    "display_name": { "type": "string", "minLength": 1 },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/option" }
    },
    "fallback_option_id": { "$ref": "#/$defs/id" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:[.-][0-9A-Za-z.-]+)?$" },
    "weight": { "type": "number", "minimum": 0 },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "operator"],
      "properties": {
        "field": { "$ref": "#/$defs/id" },
        "operator": {
          "enum": ["equals", "not_equals", "in", "not_in", "contains_tag", "missing", "present"]
        },
        "value": {}
      }
    },
    "implication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "value"],
      "properties": {
        "field": { "$ref": "#/$defs/id" },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "preference": {
      "allOf": [
        { "$ref": "#/$defs/condition" },
        {
          "type": "object",
          "properties": { "multiplier": { "type": "number", "exclusiveMinimum": 0 } }
        }
      ]
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "weight": { "$ref": "#/$defs/weight" }
      }
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "text": { "type": "string", "minLength": 1 },
        "weight": { "$ref": "#/$defs/weight" },
        "tags": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "status": { "enum": ["active", "experimental", "deprecated"] },
        "semantic_key": { "type": "string", "minLength": 1 },
        "requires": { "type": "array", "items": { "$ref": "#/$defs/condition" } },
        "excludes": { "type": "array", "items": { "$ref": "#/$defs/condition" } },
        "implies": { "type": "array", "items": { "$ref": "#/$defs/implication" } },
        "prefer": { "type": "array", "items": { "$ref": "#/$defs/preference" } },
        "sentence": { "type": "string", "minLength": 1 },
        "variants": { "type": "array", "items": { "$ref": "#/$defs/variant" } },
        "join_hint": { "type": "string", "minLength": 1 }
      }
    }
  }
}
