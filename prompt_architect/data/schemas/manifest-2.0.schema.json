{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prompt-architect.invalid/schemas/2.0/manifest.schema.json",
  "title": "Prompt Architect Manifest 2.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "engine_version",
    "profile",
    "libraries",
    "catalog_version",
    "packs",
    "configuration_hash",
    "effective_configuration",
    "master_seed",
    "group_seeds",
    "selections",
    "applied_rules",
    "resolved_conflicts",
    "fallbacks",
    "attempts",
    "warnings",
    "positive_prompt",
    "negative_prompt"
  ],
  "properties": {
    "schema_version": { "const": "2.0" },
    "engine_version": { "type": "string", "minLength": 1 },
    "profile": { "type": "object" },
    "libraries": { "type": "object", "additionalProperties": { "type": "string" } },
    "catalog_version": { "type": "string", "minLength": 1 },
    "packs": { "type": "object", "additionalProperties": { "type": "string" } },
    "configuration_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "effective_configuration": { "type": "object" },
    "master_seed": { "type": "integer", "minimum": 0 },
    "group_seeds": { "type": "object" },
    "selections": { "type": "object" },
    "applied_rules": { "type": "array", "items": { "type": "string" } },
    "resolved_conflicts": { "type": "array", "items": { "type": "string" } },
    "fallbacks": { "type": "array", "items": { "type": "string" } },
    "attempts": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "positive_prompt": { "type": "string", "minLength": 1 },
    "negative_prompt": { "type": "string" }
  }
}
