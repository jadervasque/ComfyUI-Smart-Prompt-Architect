{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prompt-architect.invalid/schemas/1.1/configuration.schema.json",
  "title": "Prompt Architect Node Configuration 1.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_id", "mode", "master_seed"],
  "properties": {
    "schema_version": { "const": "1.1" },
    "profile_id": { "$ref": "#/$defs/id" },
    "profile_version": { "$ref": "#/$defs/version" },
    "mode": { "enum": ["strict", "balanced", "creative", "dataset", "sequential"] },
    "master_seed": { "type": "integer", "minimum": 0, "maximum": 18446744073709551615 },
    "batch_index": { "type": "integer", "minimum": 0 },
    "groups": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "locked": { "type": "boolean" },
          "seed": { "type": "integer", "minimum": 0, "maximum": 18446744073709551615 }
        }
      }
    },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mode"],
        "properties": {
          "mode": { "enum": ["disabled", "fixed", "custom", "random", "inherit"] },
          "value": { "type": "string", "minLength": 1, "maxLength": 4096 },
          "include_tags": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "exclude_tags": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
        },
        "allOf": [
          {
            "if": { "properties": { "mode": { "enum": ["fixed", "custom"] } } },
            "then": { "required": ["value"] }
          }
        ]
      }
    },
    "overrides": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:[.-][0-9A-Za-z.-]+)?$" }
  }
}
