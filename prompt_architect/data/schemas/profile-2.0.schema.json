{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prompt-architect.invalid/schemas/2.0/profile.schema.json",
  "title": "Prompt Architect Profile 2.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "version",
    "display_name",
    "language",
    "catalog_version",
    "enabled_packs",
    "allowed_safety_classes",
    "verbosity",
    "negative_level",
    "minimum_sections",
    "minimum_prompt_characters",
    "max_selection_attempts",
    "section_order",
    "sections",
    "templates"
  ],
  "properties": {
    "schema_version": { "const": "2.0" },
    "id": { "$ref": "#/$defs/id" },
    "version": { "$ref": "#/$defs/version" },
    "display_name": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "minLength": 1 },
    "catalog_version": { "$ref": "#/$defs/version" },
    "enabled_packs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "allowed_safety_classes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["general", "fashion-mature", "dark-atmospheric", "experimental"]
      }
    },
    "verbosity": { "enum": ["compact", "standard", "detailed"] },
    "negative_level": { "enum": ["minimal", "standard", "strict"] },
    "minimum_sections": { "type": "integer", "minimum": 1 },
    "minimum_prompt_characters": { "type": "integer", "minimum": 1 },
    "max_selection_attempts": { "type": "integer", "minimum": 1 },
    "section_order": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "sections": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/section" }
    },
    "templates": {
      "type": "object",
      "required": ["positive"],
      "additionalProperties": { "type": "string" }
    },
    "profile_fallbacks": { "type": "object" },
    "allow_empty_negative": { "type": "boolean" },
    "metadata": { "type": "object" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[.-][0-9A-Za-z.-]+)?$"
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "library", "mode", "group"],
      "properties": {
        "required": { "type": "boolean" },
        "library": { "$ref": "#/$defs/id" },
        "mode": { "enum": ["disabled", "fixed", "random", "inherit"] },
        "group": { "$ref": "#/$defs/id" },
        "default": { "$ref": "#/$defs/id" },
        "fallback": { "$ref": "#/$defs/id" }
      }
    }
  }
}
