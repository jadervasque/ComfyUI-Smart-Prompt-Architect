{
  "schema_version":"1.0","id":"dataset","version":"1.0.0","display_name":"Dataset","language":"en",
  "minimum_sections":10,"minimum_prompt_characters":180,"max_selection_attempts":25,
  "section_order":["subject","identity","face","eyes","skin","hair-length","hair-style","outfit","expression","pose","location","lighting","camera","composition","quality","negative"],
  "sections":{
    "subject":{"required":true,"library":"subjects","mode":"fixed","default":"adult-person","group":"identity","fallback":"adult-person"},
    "identity":{"required":true,"library":"identity","mode":"fixed","default":"distinct-natural-features","group":"identity","fallback":"distinct-natural-features"},
    "face":{"required":true,"library":"face","mode":"random","group":"identity","fallback":"oval-face"},
    "eyes":{"required":true,"library":"eyes","mode":"random","group":"identity","fallback":"brown-eyes"},
    "skin":{"required":true,"library":"skin","mode":"random","group":"appearance","fallback":"natural-skin-texture"},
    "hair-length":{"required":true,"library":"hair-length","mode":"random","group":"appearance","fallback":"medium-hair"},
    "hair-style":{"required":true,"library":"hair-style","mode":"random","group":"appearance","fallback":"loose-hair"},
    "outfit":{"required":true,"library":"outfit","mode":"random","group":"outfit","fallback":"casual-jacket"},
    "expression":{"required":true,"library":"expression","mode":"random","group":"pose","fallback":"calm-expression"},
    "pose":{"required":true,"library":"pose","mode":"random","group":"pose","fallback":"relaxed-standing"},
    "location":{"required":true,"library":"location","mode":"random","group":"scene","fallback":"neutral-studio"},
    "lighting":{"required":true,"library":"lighting","mode":"random","group":"lighting","fallback":"soft-window-light"},
    "camera":{"required":true,"library":"camera","mode":"random","group":"camera","fallback":"standard-lens"},
    "composition":{"required":true,"library":"composition","mode":"random","group":"camera","fallback":"three-quarter-frame"},
    "quality":{"required":true,"library":"quality","mode":"fixed","default":"clean-dataset-detail","group":"quality","fallback":"clean-dataset-detail"},
    "negative":{"required":false,"library":"negative","mode":"random","group":"negative","fallback":"common-artifacts"}
  },
  "templates":{"positive":"{subject}. {identity}. {face}. {eyes}. {skin}. {hair-length}. {hair-style}. {outfit}. {expression}. {pose}. {location}. {lighting}. {camera}. {composition}. {quality}.","negative":"{negative_global}."},
  "allow_empty_negative":false,
  "metadata":{"purpose":"reproducible adult training dataset","content_policy":"adults-only"}
}
