{
  "schema_version":"1.0","id":"portrait","version":"1.0.0","display_name":"Portrait","language":"en",
  "minimum_sections":10,"minimum_prompt_characters":180,"max_selection_attempts":20,
  "section_order":["subject","face","eyes","skin","hair-color","hair-length","hair-texture","hair-style","expression","pose","location","lighting","camera","composition","quality","negative"],
  "sections":{
    "subject":{"required":true,"library":"subjects","mode":"fixed","default":"adult-person","group":"identity","fallback":"adult-person"},
    "face":{"required":true,"library":"face","mode":"random","group":"identity","fallback":"oval-face"},
    "eyes":{"required":true,"library":"eyes","mode":"random","group":"identity","fallback":"brown-eyes"},
    "skin":{"required":true,"library":"skin","mode":"random","group":"appearance","fallback":"natural-skin-texture"},
    "hair-color":{"required":true,"library":"hair-color","mode":"random","group":"appearance","fallback":"brown-hair"},
    "hair-length":{"required":true,"library":"hair-length","mode":"random","group":"appearance","fallback":"medium-hair"},
    "hair-texture":{"required":true,"library":"hair-texture","mode":"random","group":"appearance","fallback":"wavy-hair"},
    "hair-style":{"required":true,"library":"hair-style","mode":"random","group":"appearance","fallback":"loose-hair"},
    "expression":{"required":true,"library":"expression","mode":"random","group":"pose","fallback":"calm-expression"},
    "pose":{"required":true,"library":"pose","mode":"random","group":"pose","fallback":"relaxed-standing"},
    "location":{"required":true,"library":"location","mode":"random","group":"scene","fallback":"neutral-studio"},
    "lighting":{"required":true,"library":"lighting","mode":"random","group":"lighting","fallback":"soft-window-light"},
    "camera":{"required":true,"library":"camera","mode":"random","group":"camera","fallback":"portrait-lens"},
    "composition":{"required":true,"library":"composition","mode":"random","group":"camera","fallback":"head-and-shoulders"},
    "quality":{"required":true,"library":"quality","mode":"random","group":"quality","fallback":"natural-photographic-detail"},
    "negative":{"required":false,"library":"negative","mode":"random","group":"negative","fallback":"portrait-artifacts"}
  },
  "templates":{"positive":"{subject}. {face}. {eyes}. {skin}. {hair-color}. {hair-length}. {hair-texture}. {hair-style}. {expression}. {pose}. {location}. {lighting}. {camera}. {composition}. {quality}.","negative":"{negative_global}."},
  "allow_empty_negative":false,
  "metadata":{"purpose":"photographic portrait","content_policy":"adults-only"}
}
